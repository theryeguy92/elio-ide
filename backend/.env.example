# ── Storage ────────────────────────────────────────────────────────────────
# Pick one, or leave both blank to use local SQLite (backend/local.db).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── GPU rental ─────────────────────────────────────────────────────────────
# Optional. Leave blank to run in local mode (all GPU endpoints return a
# "local mode" response instead of calling RunPod).
RUNPOD_API_KEY=

# ── AI descriptions ─────────────────────────────────────────────────────────
# Optional. Without this key the Stakeholder tab generates rule-based
# descriptions from trace data instead of calling Claude.
ANTHROPIC_API_KEY=

# ── Git integration ─────────────────────────────────────────────────────────
# Path to the project git repository. Defaults to current directory.
GIT_REPO_PATH=/home/levey/elio-ide
